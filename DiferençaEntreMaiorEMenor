#include <stdio.h>

int main() {
    int n1;
    int n2;
    int n3;
    int diferenca;
    int maior, menor;

    scanf("%d %d %d", &n1, &n2, &n3);

    maior = n1;
    menor = n1;

    if (maior < n2) {
        maior = n2;
    }
    if (maior < n3) {
        maior = n3;
    }

    if (menor > n2) {
        menor = n2;
    }
    if (menor > n3) {
        menor = n3;
    }

    diferenca = maior - menor;

    printf("%d", diferenca);

    return 0;
}
